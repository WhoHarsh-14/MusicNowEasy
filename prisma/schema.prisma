// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model QueryHistory {
  id         String   @id @default(uuid())
  query      String
  songCount  Int      @map("song_count")
  songsJson  Json     @map("songs_json")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("query_history")
}
